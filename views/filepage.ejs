<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/css/style.css">
    <title>Dosya Format Dönüştürücü</title>
</head>
<body>
    <div class ="container">
    <div class="nav-bar">
        <a href="/" class="back-link">← Ana Panel</a>
        <span class="version-tag">Hızlı Dönüştürme</span>
    </div>

    <div class ="card">
        <h2 class="title text-center" style="font-size: 1.75rem;">Dosya Format Dönüştürücü</h2>
        <p class="subtitle text-center">Dosyanızı seçin, hedef formatı belirleyin ve anında indirin.</p>

        <form action="/dosya/convert" method="POST" enctype="multipart/form-data" id="convertForm">
            <div class="form-group">
                <label for="fileInput">Yüklenecek Dosya (PDF, DOCX, XLSX, PPTX):</label>
                <input type="file" name="document" id="fileInput" required accept=".pdf,.docx,.xlsx,.pptx">
            </div>

            <div class="flex-group form-group">
                <div class="flex-item">
                    <label for="fromFormat">Mevcut Format:</label>
                    <select name="fromFormat" id="fromFormat" required>
                        <option value="pdf">PDF</option>
                        <option value="docx">DOCX</option>
                        <option value="xlsx">XLSX</option>
                        <option value="pptx">PPTX</option>
                    </select>
                </div>

                <div class="flex-item">
                    <label for="toFormat">Hedef Format:</label>
                    <select name="toFormat" id="toFormat" required>
                        <option value="pdf">PDF</option>
                        <option value="docx">DOCX</option>
                        <option value="xlsx">XLSX</option>
                        <option value="pptx">PPTX</option>
                    </select>
                </div>
            </div>

            <button type="submit" class="btn">Dönüştür ve İndir</button>
        </form>
    </div>
    </div>

    
</body>


<script>
    const fileInput = document.getElementById('fileInput');
    const fromFormatSelect = document.getElementById('fromFormat');
    const toFormatSelect = document.getElementById('toFormat');

    fileInput.addEventListener('change', function(e) {
        const file = e.target.files[0];
        if (!file) return;

        const fileName = file.name.toLowerCase().trim();
        const fileExtension = fileName.split('.').pop().trim();

        const finalExtension = fileExtension === 'docx' ? 'docx' : fileExtension;

        console.log(`Yüklenen dosya: ${fileName}, Uzantı: ${fileExtension}`);

        const hasOption = Array.from(fromFormatSelect.options).some(option => option.value === finalExtension);
        if (hasOption) {
            fromFormatSelect.value = finalExtension;
            console.log(`Mevcut format seçildi: ${finalExtension.toUpperCase()}`);
        } else {
            fromFormatSelect.value = '';
        }

        if (fromFormatSelect.value === toFormatSelect.value) {
            if(fileExtension === "pdf") {
                toFormatSelect.value = 'docx';
            } else {
                toFormatSelect.value = 'pdf';
            }
        }

    });
    

    document.getElementById('convertForm').addEventListener('submit', function(e) {
        const fromFmt = document.getElementById('fromFormat').value;
        const toFmt = document.getElementById('toFormat').value;

        if (fromFmt === toFmt) {
            e.preventDefault();
            alert('Mevcut format ve hedef format aynı olamaz. Lütfen farklı bir hedef format seçin.');
        }
    });


</script>


</html>