<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Çevrimiçi Dinamik Karekod Üretim İstasyonu</title>
    <!-- Harici CSS Dosyamız -->
    <link rel="stylesheet" href="/css/style.css">
    <!-- İkonlar İçin FontAwesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body>

    <!-- ⏳ Gizli Yükleniyor Ekranı -->
    <div id="loading-overlay" class="overlay hidden">
        <div class="spinner"></div>
        <h3 style="font-weight: 700; font-size: 1.25rem;">Karekodunuz Üretiliyor...</h3>
        <p style="font-size: 0.875rem; color: #cbd5e1; margin-top: 0.25rem;">Lütfen bekleyin, veri işleniyor ve görsel şablon hazırlanıyor.</p>
    </div>

    <!-- 🌐 Üst Menü -->
    <header>
        <div class="header-container">
            <div class="logo-area">
                <div class="logo-icon"><i class="fa-solid fa-wand-magic-sparkles"></i></div>
                <span class="logo-text" style="color: #0f172a;">Medya Dönüştürücü</span>
            </div>
            <a href="/" style="font-size: 0.875rem; color: #475569; text-decoration: none; font-weight: 500;"><i class="fa-solid fa-house"></i> Ana Panel</a>
        </div>
    </header>

    <!-- 🚀 Ana İçerik -->
    <main>
        <div class="hero-area">
            <h1>Dinamik Karekod Üretici</h1>
            <p>Web siteleri, dijital menüler veya metin içerikleri için anında taranabilir yüksek kalitede karekodlar oluşturun.</p>
        </div>

        <section class="card">
            <form action="/qr/generate" method="POST">
                
                <!-- Bağlantı Girişi -->
                <div class="form-group">
                    <label for="link">Hedef Bağlantı (URL) veya Metin İçeriği</label>
                    <input type="text" id="link" name="link" placeholder="https://orneklink.com/menu.pdf" required>
                    <p style="font-size: 11px; color: #94a3b8; margin-top: 5px;">Karekodun yönlendireceği internet adresini eksiksiz (http/https dahil) yazın.</p>
                </div>

                <!-- Buton -->
                <button type="submit" class="btn btn-indigo">
                    <i class="fa-solid fa-qrcode"></i> Karekod Oluştur
                </button>
            </form>
        </section>
    </main>

    <!-- 📜 Alt Bilgi -->
    <footer>
        &copy; 2026 Çevrimiçi Medya Dönüştürme Platformu.
    </footer>

    <!-- 🛠️ Ön Yüz Kontrolleri -->
    <script>
        document.querySelector('form').addEventListener('submit', function(e) {
            const linkInput = document.getElementById('link').value.trim();
            
            if (linkInput === "") {
                e.preventDefault();
                alert("Lütfen geçerli bir bağlantı veya metin girin.");
                return false;
            }

            // Yükleniyor ekranını aç
            document.getElementById('loading-overlay').classList.remove('hidden');
            const btn = this.querySelector('button[type="submit"]');
            if (btn) {
                btn.disabled = true;
                btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Üretiliyor...';
            }
        });
    </script>
</body>
</html>