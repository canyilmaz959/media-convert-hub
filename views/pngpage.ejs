<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/css/style.css">
    <title>Görsel Format Dönüştürücü</title>
</head>
<body>

    <div class="container">
    <div class="nav-bar">
        <a href="/" class="back-link">← Ana Panel</a>
        <span class="version-tag">Hızlı Dönüştürme</span>
    </div>

    <div class="card">
        <h2 class="title text-center" style="font-size: 1.75rem;">Görsel Format Dönüştürücü</h2>
        <p class="subtitle text-center">Dosyanızı seçin, hedef formatı belirleyin ve anında indirin.</p>

        <form action="/gorsel/convert" method="POST" enctype="multipart/form-data" id="convertForm">
            <div class="form-group">
                <label for="imageInput">Yüklenecek Dosya (PNG, JPG, WebP, SVG):</label>
                <input type="file" name="image" id="imageInput" required accept=".png,.jpg,.jpeg,.webp,.svg">
            </div>

            <div class="flex-group form-group">
                <div class="flex-item">
                    <label for="fromFormat">Mevcut Format:</label>
                    <select name="fromFormat" id="fromFormat" required>
                        <option value="png">PNG</option>
                        <option value="jpg">JPG / JPEG</option>
                        <option value="webp">WebP</option>
                        <option value="svg">SVG</option>
                    </select>
                </div>

                <div class="flex-item">
                    <label for="toFormat">Hedef Format:</label>
                    <select name="toFormat" id="toFormat" required>
                        <option value="jpg">JPG</option>
                        <option value="png">PNG</option>
                        <option value="webp">WebP</option>
                        <option value="svg">SVG</option>
                    </select>
                </div>
            </div>

            <button type="submit" class="btn">Dönüştür ve İndir</button>
        </form>
    </div>
</div>

    <script>
    const imageInput = document.getElementById('imageInput');
    const fromFormatSelect = document.getElementById('fromFormat');

    imageInput.addEventListener('change', function(e) {
        const file = e.target.files[0];
        if (!file) return;

        const fileName = file.name.toLowerCase();
        const fileExtension = fileName.split('.').pop();

        const finalExtension = fileExtension === 'jpeg' ? 'jpg' : fileExtension;

        const hasOption = Array.from(fromFormatSelect.options).some(option => option.value === finalExtension);

        if (hasOption) {
            fromFormatSelect.value = finalExtension;
            console.log(`[Sistem Algıladı] Yüklenen dosya türü otomatik seçildi: ${finalExtension.toUpperCase()}`);
        }
    });
        document.getElementById('convertForm').addEventListener('submit', function(e) {
            const fromFmt = document.getElementById('fromFormat').value;
            const toFmt = document.getElementById('toFormat').value;

            if (fromFmt === toFmt) {
                e.preventDefault();
                alert('Hata: Kaynak format ile hedef format aynı olamaz! Lütfen farklı bir kombinasyon seçin.');
            }
        });
    </script>

</body>
</html>